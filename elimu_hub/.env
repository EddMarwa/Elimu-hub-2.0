# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/elimu_hub

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct

# Embedding Model Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Vector Database Configuration
VECTOR_DB_PATH=./embeddings/chroma_db
VECTOR_DB_TYPE=chromadb

# Application Settings
APP_NAME=Elimu Hub
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# File Processing Settings
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OCR Settings
TESSERACT_CMD=tesseract
OCR_LANGUAGES=eng+swa  # English and Swahili

# Supported Education Levels
EDUCATION_LEVELS=Primary,Junior Secondary,Secondary

# Default Subjects (can be extended)
DEFAULT_SUBJECTS=Mathematics,English,Kiswahili,Science,Social Studies,Religious Education
